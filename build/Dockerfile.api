FROM rinavillaruz/dota2metalab-base:latest

WORKDIR /app

COPY build/requirements-api.txt .

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements-api.txt && \
    pip install "setuptools>=80.0.0" "wheel>=0.46.2" "jaraco.context>=6.1.0"

COPY src/ src/

EXPOSE 8080

ENV PORT=8080

CMD [ "python", "src/api/app.py" ]