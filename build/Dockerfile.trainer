FROM rinavillaruz/dota2metalab-base:latest

WORKDIR /app

COPY build/requirements-trainer.txt .

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements-trainer.txt && \
    pip install "setuptools>=80.0.0" "wheel>=0.46.2" "jaraco.context>=6.1.0"

COPY scripts/ scripts/

COPY src/ src/

CMD [ "python", "scripts/train_model.py"]
