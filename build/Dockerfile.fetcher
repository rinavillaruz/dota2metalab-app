FROM python:3.11-slim 

WORKDIR /app

ENV PYTHONPATH=/app

COPY build/requirements-fetcher.txt .

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements-fetcher.txt && \
    pip install "setuptools>=80.0.0" "wheel>=0.46.2" "jaraco.context>=6.1.0"

COPY scripts/ scripts/

COPY src/ src/

CMD [ "python", "scripts/store_database.py"]
